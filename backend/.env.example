# ============================================================
#  ProConnect — Environment Variables Template
#  Copy this file, rename to .env, and fill in your values.
#  NEVER commit .env to Git.
# ============================================================

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=proconnect

# --- JWT ---
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=3000
