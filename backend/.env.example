# =============================================
#  ProConnect — Environment Variables
#  Copy this file to .env and fill in values
#  NEVER commit .env to git!
# =============================================

# Server
PORT=3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=proconnect

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
